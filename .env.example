# Required: your Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=

# Optional: pre-filter thresholds. Audio shorter than MIN_DURATION_SEC or
# quieter than MIN_RMS is dropped before being sent to the API, to avoid
# wasted calls and Whisper hallucinations on near-silence.
#WHISPERER_MIN_DURATION_SEC=0.4
#WHISPERER_MIN_RMS=250

# Optional: hard cap on recording duration in seconds. When the cap is
# reached the audio buffer freezes (no more frames captured) and a TOC
# tone signals it; the trigger still has to be released. Defends against
# stuck triggers producing multi-minute uploads. Default 300 (5 min).
#WHISPERER_MAX_RECORDING_SEC=300

# Optional: language code passed to Whisper (ISO-639-1). Used by the CLI
# (main.py) and as the fallback default when WHISPERER_LANGUAGES is not
# set. Use "en" for English, "fr" for French, etc.
#WHISPERER_LANGUAGE=es

# Optional (tray app only): comma-separated list of forced-language
# options that appear in the right-click "Language" submenu, alongside
# an automatic "Auto (detect)" entry that omits the language hint
# entirely (Whisper detects and transcribes in source language — no
# translation). The first entry is the startup default. If unset, the
# tray app falls back to [WHISPERER_LANGUAGE] and shows no submenu.
# Example for ES + EN + PT:
#WHISPERER_LANGUAGES=es,en,pt

# Trigger key for push-to-talk. Default is "ctrl derecha" (right Ctrl on
# Spanish keyboards). The app rewrites this entry when you change the
# key via the tray menu, so you usually don't edit it by hand.
#WHISPERER_TRIGGER_KEY=ctrl derecha

# Optional: prompt biasing the transcription. Should be a natural sentence
# in the target language describing the expected content. Avoid lists or
# trailing punctuation — Whisper imitates the prompt's style.
# Spanish example:
#WHISPERER_PROMPT=Transcripcion de dictado tecnico en castellano sobre desarrollo de software con Python, pandas, FastAPI, Next.js, Vercel, SQL, Anthropic Claude y MCP.
# English example:
#WHISPERER_PROMPT=Technical dictation in English about software development with Python, FastAPI, Vercel, and the Anthropic Claude API.
